# ── Email (for form notifications to yourself) ──────────────────────────
# Use Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here

# Your email — where inquiry alerts get sent
NOTIFY_EMAIL=your@gmail.com

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000

# ── Upload limits ─────────────────────────────────────────────────────────
# Max reference photo upload size in MB (for commission inquiries)
MAX_UPLOAD_MB=10
